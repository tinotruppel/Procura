# Environment Configuration
# Copy to .env and fill in your values

# Database
# Set DB_DRIVER=sqlite for local dev (in-memory, no MySQL needed)
# DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=procura
DB_USER=your_username
DB_PASSWORD=your_password

# Server
PORT=3001

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Maximum blob size in bytes (default: 50MB)
MAX_BLOB_SIZE=52428800

# API Keys (comma-separated, leave empty for open mode)
API_KEYS=

# MCP Proxy allowed domains (comma-separated, leave empty to allow all HTTPS)
MCP_PROXY_ALLOWED_DOMAINS=

# --- MCP Server Credentials ---

# OpenAI (Knowledge Base embeddings + Document/Media transcription & OCR)
OPENAI_API_KEY=your-openai-api-key

# Google Gemini (Image Generation)
GEMINI_API_KEY=your-gemini-api-key

# OpenWeatherMap (Weather)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Trello (Tasks)
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-token

# Flowcase (CV Database)
FLOWCASE_API_KEY=your-flowcase-api-key

# Qdrant (Knowledge Base)
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_EMBEDDING_MODEL=text-embedding-3-small

# GitHub
GITHUB_TOKEN=your-github-token

# Google OAuth (for Google Docs/Sheets/Slides MCP endpoints)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Token encryption key (64 hex chars, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key
