# Procura Sync & Vault Debugging
PROCURA_URL=https://api.your-domain.com/sync
PROCURA_SECURITY_KEY=your-44-char-vault-key
PROCURA_API_KEY=your-64-char-hex-api-key

# Chrome Web Store API (run: bash scripts/cws-setup.sh)
CWS_EXTENSION_ID=your-extension-id-from-dashboard
CWS_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
CWS_CLIENT_SECRET=your-oauth-client-secret
CWS_REFRESH_TOKEN=your-refresh-token
