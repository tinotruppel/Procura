{
    "manifest_version": 3,
    "name": "Procura",
    "version": "0.1.0",
    "description": "AI-powered browser assistant for process automation",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png"
        },
        "default_title": "Procura"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "sidePanel",
        "activeTab",
        "tabs",
        "scripting",
        "identity"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "screenshot-content.js",
                "deeplink-content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}