# Procura Frontend Environment Variables
# Copy to .env and fill in your values

# Backend API base URL (used for cloud sync, MCP proxy, and MCP directory defaults)
VITE_API_BASE_URL=https://api.your-domain.com

# Deep link domain (used by the content script to intercept links with promptId/agentMsg params)
VITE_DEEPLINK_DOMAIN=your-domain.com

# Base path for PWA deployment (default: "/", use e.g. "/procura/" for subpath deployment)
VITE_BASE_PATH=/
